# Copy this file to hosts.ini and fill in the IPs printed by Terraform outputs.
# Authentication is password-based (no SSH keys), matching the Terraform config.
#
# Provide the password securely at run time, e.g.:
#   ansible-playbook playbooks/db.yml  --extra-vars "ansible_password=$ADMIN_PASSWORD"
#   ansible-playbook playbooks/app.yml --extra-vars "ansible_password=$ADMIN_PASSWORD"

[app]
app-server ansible_host=<APP_PUBLIC_IP>

[db]
db-server ansible_host=<DB_PUBLIC_IP>

[all:vars]
# Azure VMs use 'azureuser'; AWS Ubuntu EC2 uses 'ubuntu'.
ansible_user=azureuser
ansible_ssh_common_args=-o StrictHostKeyChecking=no

# Private IP of the DB host so the app can reach MySQL inside the network.
db_private_ip=<DB_PRIVATE_IP>

# MySQL application database/credentials created on the db host.
mysql_database=erp
mysql_app_user=erp_app
# Pass mysql_app_password and mysql_root_password as extra-vars at run time.
